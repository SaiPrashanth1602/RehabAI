# =============================================================================
# RehabAI — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.
# =============================================================================

# --- Firebase Credentials ---
# Paste the full contents of your firebase_key.json as a single JSON string.
# On Windows PowerShell: $env:FIREBASE_CREDENTIALS = Get-Content backend/credentials/firebase_key.json -Raw
# On Linux/Mac: export FIREBASE_CREDENTIALS=$(cat backend/credentials/firebase_key.json)
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"..."}

# --- Backend API URL (override for local development) ---
# Default (production): https://rehabai-backend-j814.onrender.com/api/v1
# For local backend:    http://localhost:8000/api/v1
API_URL=http://localhost:8000/api/v1

# --- Backend Settings ---
# Leave blank to use defaults
PROJECT_NAME=RehabAI Backend API
VERSION=1.0
